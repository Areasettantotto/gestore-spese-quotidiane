# Copy to .env or .env.local and fill with your Supabase project values.
# Do not commit real keys. Never use service_role in the client.

# Required — Supabase project URL (Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Required — Supabase anon (public) key; security is enforced by RLS + Auth
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional — only used if vite.config.ts injects Gemini (local / optional features)
# GEMINI_API_KEY=your-gemini-api-key-placeholder
