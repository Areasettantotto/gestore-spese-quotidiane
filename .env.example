# Local development template for React/Vite + Supabase local.
# Do not commit real keys. Never use service_role in the client.

# Supabase local project URL (from `npx supabase start`)
VITE_SUPABASE_URL=http://127.0.0.1:54321

# Use only local publishable/anon key (from `npx supabase start`)
VITE_SUPABASE_ANON_KEY=your-local-supabase-publishable-or-anon-key

# Optional — only used if vite.config.ts injects Gemini (local / optional features)
# GEMINI_API_KEY=your-gemini-api-key-placeholder
